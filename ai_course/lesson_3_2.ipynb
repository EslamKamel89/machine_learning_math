   "source": [
    "v = np.array([3, 4])\n",
    "u = np.array([1, 0])\n",
    "projection = (np.dot(v , u) / np.dot(u , u)) * u\n",
    "pr(projection , 'projection')\n",
    "error = v - projection\n",
    "pr(error , 'error')"
